<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F1115">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_dialog"
            android:padding="20dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🍳 Створення рецепта"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_below="@id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Поділіться своїм смачним рецептом зі спільнотою"
                android:textColor="#888"
                android:textSize="12sp"
                android:layout_marginTop="4dp"/>

            <ImageButton
                android:id="@+id/btnClose"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_alignParentEnd="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="@color/white"/>
        </RelativeLayout>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="📝 Назва рецепта" android:textColor="@color/white" android:layout_marginBottom="8dp"/>
        <EditText
            android:id="@+id/etRecipeTitle"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Введіть назву рецепту"
            android:textColorHint="#444"
            android:background="@drawable/bg_input"
            android:paddingHorizontal="16dp"
            android:textColor="@color/white"
            android:layout_marginBottom="20dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:weightSum="3" android:layout_marginBottom="20dp">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⚡ Складність" android:textColor="@color/white" android:textSize="12sp" android:layout_marginBottom="4dp"/>
                <Spinner android:id="@+id/spinDifficulty" android:layout_width="match_parent" android:layout_height="45dp" android:background="@drawable/bg_input" android:spinnerMode="dropdown"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🕒 Час (хв)" android:textColor="@color/white" android:textSize="12sp" android:layout_marginBottom="4dp"/>
                <EditText
                    android:id="@+id/etRecipeTime"
                    android:layout_width="match_parent"
                    android:layout_height="45dp"
                    android:background="@drawable/bg_input"
                    android:inputType="number"
                    android:textColor="@color/white"
                    android:gravity="center"
                    android:hint="30"
                    android:textColorHint="#444"
                    android:paddingHorizontal="8dp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Категорія" android:textColor="@color/white" android:textSize="12sp" android:layout_marginBottom="4dp"/>
                <Spinner android:id="@+id/spinCategory" android:layout_width="match_parent" android:layout_height="45dp" android:background="@drawable/bg_input" android:spinnerMode="dropdown"/>
            </LinearLayout>
        </LinearLayout>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="📸 Додати фото *" android:textColor="@color/white" android:layout_marginBottom="8dp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="20dp">
            <Button
                android:id="@+id/btnSelectFile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Виберіть файл"
                android:textAllCaps="false"
                android:backgroundTint="@color/white"
                android:textColor="@color/black"/>
            <TextView android:id="@+id/tvFileName" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Файл не обраний" android:textColor="#888" android:layout_marginStart="12dp"/>
        </LinearLayout>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="📋 Інгредієнти" android:textColor="@color/white" android:layout_marginBottom="8dp"/>
        <LinearLayout android:id="@+id/containerIngredients" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical"/>
        <Button
            android:id="@+id/btnAddIngredient"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="+ Додати інгредієнт"
            android:textColor="#FF7A45"
            android:background="@android:color/transparent"
            android:textAllCaps="false"
            android:layout_marginBottom="20dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="🍳 Етапи приготування" android:textColor="@color/white" android:layout_marginBottom="8dp"/>
        <LinearLayout android:id="@+id/containerSteps" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical"/>
        <Button
            android:id="@+id/btnAddStep"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="+ Додати етап"
            android:textColor="#FF7A45"
            android:background="@android:color/transparent"
            android:textAllCaps="false"
            android:layout_marginBottom="32dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnPublish"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="🚀 Опублікувати рецепт"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:background="@drawable/bg_button"/>

    </LinearLayout>
</ScrollView>